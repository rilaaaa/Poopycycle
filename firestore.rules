rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if document belongs to authenticated user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for users collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for poops collection
    match /poops/{poopId} {
      allow read, create, update, delete: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // Rules for meals collection
    match /meals/{mealId} {
      allow read, create, update, delete: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // Rules for symptoms collection
    match /symptoms/{symptomId} {
      allow read, create, update, delete: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // Rules for waters collection
    match /waters/{waterId} {
      allow read, create, update, delete: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // Rules for activities collection
    match /activities/{activityId} {
      allow read, create, update, delete: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || resource.data.userId == request.auth.uid);
    }
  }
}
